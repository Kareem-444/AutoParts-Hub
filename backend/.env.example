# ---------------------------------------------------------------------------
# AutoParts Hub - Backend Environment Variables
# Copy this file to .env and fill in the values.
# ---------------------------------------------------------------------------

# Secret key (REQUIRED - generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-secret-key-here

# Debug mode (True for local dev, False for production)
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL for production, leave unset for local SQLite)
DATABASE_URL=postgresql://user:password@localhost:5432/autoparts_db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Google OAuth (get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary (get from https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
