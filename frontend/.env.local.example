# ---------------------------------------------------------------------------
# AutoParts Hub - Frontend Environment Variables
# Copy this file to .env.local and fill in the values.
# ---------------------------------------------------------------------------

# Backend API URL
# Local dev:  http://localhost:8000/api
# Production: https://autoparts-hub-production.up.railway.app/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Google OAuth Client ID (from https://console.cloud.google.com/)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudinary Cloud Name (from https://cloudinary.com/console)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Groq API Key (for Aria AI Assistant)
NEXT_PUBLIC_GROQ_API_KEY=
